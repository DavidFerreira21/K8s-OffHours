# Required
SCHEDULE_NAME=dev
ACTION=shutdown
ARGO_ENABLED=false

# Optional schedule scope
# namespace  -> select namespaces by offhours.platform.io/schedule label
# deployment -> select deployments by offhours.platform.io/schedule label
SCHEDULE_SCOPE=namespace

# Required only if ARGO_ENABLED=true
ARGO_SERVER=argocd.example.com
ARGO_TOKEN=<token>
ARGO_SCHEME=https
ARGO_INSECURE=false

# Argo discovery controls
ARGO_DISCOVERY_USE_INSTANCE_LABEL=true
ARGO_DISCOVERY_USE_TRACKING_ID=true
ARGO_DISCOVERY_USE_ARGOPP=false
ARGO_DISCOVERY_USE_DEST_NAMESPACE_FALLBACK=false

# Argo API retry/backoff
ARGO_API_RETRIES=2
ARGO_API_RETRY_BASE_SECONDS=0.2
ARGO_API_RETRY_MAX_SECONDS=1.0

# Optional
VERBOSE=false
DRY_RUN=false
DEFAULT_STARTUP_REPLICAS=1
PROTECTED_APP_STRICT_MODE=true
